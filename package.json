{
  "name": "defi-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "ui": "turbo run storybook --filter=@defi/ui",
    "app": "turbo run dev --filter=@defi/app"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
