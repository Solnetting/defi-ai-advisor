{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "storybook-static/**"],
      "env": ["GROQ_API_KEY", "HELIUS_API_KEY"]
    },
    "storybook": {
      "persistent": true,
      "cache": false
    }
  }
}
